# OneSignal Push Notification Credentials
ONESIGNAL_APP_ID=your_onesignal_app_id_here
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key_here

# Database Configuration
DB_HOST=localhost
DB_USER=your_db_user_here
DB_PASS=your_db_password_here
DB_NAME=event_management_system
DB_CHARSET=utf8mb4

# TOTP 2FA Encryption Key (must be at least 16 characters, recommend 32+ random bytes)
TOTP_ENCRYPTION_KEY=your_totp_encryption_key_here

# Application Environment (development / production)
APP_ENV=development
